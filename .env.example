API_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/industrial_ai
WORKER_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/industrial_ai
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_FALLBACK_MODEL=qwen2.5:3b-instruct-q4_K_M
OLLAMA_EMBED_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=120

# Fine-tuning runtime profiles
# Docker CPU smoke profile: safe default for Mac/Windows Docker Compose demo runs.
# This is only for tiny smoke validation, not realistic large-model training.
# TRAINING_DEVICE=cpu
# TRAINING_ALLOW_CPU=true
# FT_ALLOW_SMOKE_FALLBACK=true
# FT_SMOKE_FALLBACK_BACKEND=deterministic_smoke
# FT_MAX_SEQ_LENGTH=256
# FT_DEFAULT_TRAINING_METHOD=sft_lora
# FT_TRAINER_BACKEND=local_peft
# FT_TRAINER_MODEL_MAP_JSON={"qwen2.5:7b-instruct-q4_K_M":"hf-internal/testing-tiny-random-gpt2"}

# Host Apple Silicon MPS profile: recommended when you want accelerator validation
# from a host worker runtime instead of a Docker Linux worker.
TRAINING_DEVICE=mps
TRAINING_ALLOW_CPU=false
MODEL_ARTIFACT_DIR=data/model_artifacts
FT_MAX_SEQ_LENGTH=1024
FT_DEFAULT_TRAINING_METHOD=sft_lora
FT_TRAINER_BACKEND=local_peft
FT_ALLOW_SMOKE_FALLBACK=false
FT_SMOKE_FALLBACK_BACKEND=deterministic_smoke
# Map the serving/base lineage name to a small trainer checkpoint for local smoke tests.
# The first run may need network access to download the tiny trainer model if it is not cached.
FT_TRAINER_MODEL_MAP_JSON={"qwen2.5:7b-instruct-q4_K_M":"hf-internal/testing-tiny-random-gpt2"}

# Publish/import seam
OLLAMA_PUBLISH_ENABLED=false
OLLAMA_MODEL_NAMESPACE=demo
