# Copy to .env and adjust. The defaults target the Docker Compose stack
# (postgres + ollama + open-webui + api + worker) and need no edits for a
# basic Docker-only run.

# --- Database ---
# Inside compose, host is the `postgres` service. For local (non-Docker) dev
# against a host Postgres, use 127.0.0.1.
API_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/industrial_ai
POSTGRES_DB=industrial_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- LLM runtime (default: bundled Ollama container) ---
# Provider: "ollama" (default) or "openai_compat".
LLM_RUNTIME_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
LLM_CHAT_MODEL=llama3.2
LLM_EMBED_MODEL=nomic-embed-text

# --- Optional: native / external runtimes (advanced, NOT the default) ---
# To use LM Studio, a native Ollama, or any OpenAI-compatible server instead of
# the bundled Ollama container, set the provider to openai_compat and point the
# base URL at it, e.g. LM Studio on the host:
#   LLM_RUNTIME_PROVIDER=openai_compat
#   LLM_BASE_URL=http://host.docker.internal:1234/v1
#   LLM_CHAT_MODEL=<an id the runtime serves>
#
# Deprecated aliases (kept for one release): LMSTUDIO_BASE_URL / LMSTUDIO_CHAT_MODEL
# / LMSTUDIO_EMBED_MODEL still map onto the LLM_* settings above if LLM_* are unset.

# --- Open WebUI ---
OPENAI_API_KEY=sk-no-key-required

# --- Worker / dispatcher ---
# The API container runs with the in-process dispatcher off; the worker container
# runs the queue loop. For single-process local dev (no worker), set this true.
FT_BACKGROUND_DISPATCH=false
FT_DISPATCH_POLL_INTERVAL=2.0
# Max wall-clock seconds a single job (graph indexing / evaluation) may run before
# it is aborted at the next cooperative checkpoint and retried while attempts
# remain. Keep it well above LLM_TIMEOUT_SECONDS so individual calls can finish.
FT_JOB_TIMEOUT_SECONDS=1800
