# Database
API_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/industrial_ai

# LM Studio (OpenAI-compatible local serving runtime)
# Load chat/embed models in LM Studio before the API/RAG paths can answer.
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_CHAT_MODEL=qwen3.5-4b-mlx
LMSTUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
LMSTUDIO_TIMEOUT_SECONDS=600

# Fine-tuning (Mac-native MLX QLoRA)
MODEL_ARTIFACT_DIR=data/model_artifacts
FT_MAX_SEQ_LENGTH=1024
FT_DEFAULT_TRAINING_METHOD=sft_qlora
FT_TRAINER_BACKEND=mlx_qlora
FT_ALLOW_SMOKE_FALLBACK=false
FT_SMOKE_FALLBACK_BACKEND=deterministic_smoke
# Map the serving/base lineage name to a small trainer checkpoint for local smoke tests.
# First run may need network access to download the trainer model if it is not cached.
FT_TRAINER_MODEL_MAP_JSON={"qwen3.5-4b-mlx":"mlx-community/Qwen2.5-0.5B-Instruct-4bit"}

# Publish seam (reviewer-only manifest; no automatic LM Studio import yet)
ADAPTER_PUBLISH_ENABLED=false
MLX_MODEL_NAMESPACE=demo
